# Google Places API Key
# Required to auto-fetch live reviews from Google for UJ Pallazzio.
# Steps:
#   1. Go to https://console.cloud.google.com/
#   2. Enable "Places API (New)" for your project
#   3. Create an API key and restrict it to your domain
#   4. Copy the key below and rename this file to .env
#
# NOTE: The Google Places API (New) returns a maximum of 5 reviews per request.
#       If fewer reviews are returned, the section will display curated static reviews as fallback.

VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
